{
  "name": "telegram-codex-remote-control",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "node --import tsx/esm src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "bundle:sea": "node scripts/build-native.mjs --bundle-only",
    "package:native": "node scripts/build-native.mjs",
    "package:docker": "docker build -f docker/Dockerfile -t telegram-codex-remote-control:local ."
  },
  "dependencies": {
    "@openai/codex-sdk": "^0.144.1",
    "dotenv": "^17.4.2",
    "grammy": "^1.44.0",
    "mime-types": "^3.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^26.1.0",
    "esbuild": "^0.28.1",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
